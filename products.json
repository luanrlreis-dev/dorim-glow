backend:
  name: git-gateway
  branch: main

media_folder: "images/products"
public_folder: "/images/products"

locale: "pt"

collections:
  - name: "products"
    label: "Catálogo"
    files:
      - file: "data/products.json"
        label: "Produtos da loja"
        name: "catalog"
        fields:
          - label: "Logo da loja (topo do site)"
            name: "logo"
            widget: "image"
            media_folder: "/images"
            public_folder: "/images"
            required: false

          - label: "Produtos"
            name: "products"
            widget: "list"
            summary: "{{name}} — R$ {{price}}"
            fields:
              - {label: "Identificador único (sem espaços/acentos)", name: "id", widget: "string", hint: "ex: batom-vermelho"}
              - {label: "Nome do produto", name: "name", widget: "string"}
              - {label: "Descrição", name: "desc", widget: "text", required: false}
              - {label: "Preço (R$)", name: "price", widget: "number", value_type: "float", step: 0.01}
              - {label: "Categoria (tag no card)", name: "tag", widget: "string", required: false, hint: "ex: Lábios, Skincare, Unhas"}
              - {label: "Foto do produto", name: "image", widget: "image"}
              - label: "Cores / variações (opcional)"
                name: "swatches"
                widget: "list"
                required: false
                summary: "{{color}}"
                fields:
                  - {label: "Nome da cor/sabor", name: "color", widget: "string"}
                  - {label: "Cor do círculo (hex)", name: "hex", widget: "color"}
                  - {label: "Vem selecionada por padrão?", name: "active", widget: "boolean", default: false, required: false}
